{
  "name": "commercial-area-analysis-mvp",
  "private": true,
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:api": "cd apps/api && .venv/bin/uvicorn app.main:app --app-dir . --reload --host 127.0.0.1 --port 8000",
    "dev:web": "pnpm --filter commercial-area-analysis-web dev"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
